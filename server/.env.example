# Copy this file to .env and fill in the values
# Never commit .env to git

PORT=3001
NODE_ENV=development

# Required — generate a strong random string for production
# e.g.: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Stripe (optional — only needed for invoice payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGIN=http://localhost:5173

# Google Forms webhook — generate any strong random string, then put the same
# value in the Apps Script (see docs). e.g.: openssl rand -hex 32
GOOGLE_FORMS_WEBHOOK_SECRET=change_me
